{
  "name": "control-center",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "concurrently -n server,web -c magenta,cyan \"pnpm --filter @cc/server dev\" \"pnpm --filter @cc/web dev\"",
    "build": "pnpm --filter server build && pnpm --filter web build",
    "test": "pnpm -r test",
    "check": "biome check .",
    "fix": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "concurrently": "^9.1.0",
    "typescript": "^5.6.3"
  }
}
